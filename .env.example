# =============================================================================
# Variáveis de Ambiente - Leitura ATS
# =============================================================================
# Copie este arquivo para .env e configure os valores
# cp .env.example .env

# -----------------------------------------------------------------------------
# Aplicação Flask
# -----------------------------------------------------------------------------

# Chave secreta para sessões Flask (usada pelo app.py)
# Em produção, use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Ambiente de execução (development | production)
FLASK_ENV=development

# Debug mode (apenas development)
FLASK_DEBUG=true

# -----------------------------------------------------------------------------
# Gunicorn (usado pelo gunicorn_config.py)
# -----------------------------------------------------------------------------

# Número de workers (padrão: 2 * CPU + 1)
# GUNICORN_WORKERS=4

# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Notas
# -----------------------------------------------------------------------------
# 
# Desenvolvimento:
#   - Use os valores padrão acima
#   - FLASK_DEBUG=true para auto-reload
#
# Produção:
#   - Gere SECRET_KEY forte e única
#   - FLASK_ENV=production
#   - FLASK_DEBUG=false
