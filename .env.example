# =============================================================================
# Variáveis de Ambiente - Leitura ATS
# =============================================================================
# Copie este arquivo para .env e configure os valores
# cp .env.example .env

# -----------------------------------------------------------------------------
# Aplicação Flask
# -----------------------------------------------------------------------------

# Chave secreta para sessões Flask
# IMPORTANTE: Em produção, use uma chave forte e única!
# Gerar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-secreta-aqui-mude-em-producao

# Ambiente de execução
# Valores: development, production
FLASK_ENV=development

# Debug mode (apenas development)
# Valores: true, false
FLASK_DEBUG=true

# Porta da aplicação
FLASK_PORT=5000

# -----------------------------------------------------------------------------
# Limites
# -----------------------------------------------------------------------------

# Tamanho máximo de upload em bytes (padrão: 16MB)
MAX_CONTENT_LENGTH=16777216

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Nível de log
# Valores: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Diretório de logs (relativo à pasta aplicacao/)
LOG_DIR=logs

# -----------------------------------------------------------------------------
# AWS (para deploy futuro)
# -----------------------------------------------------------------------------

# Região AWS
# AWS_REGION=us-east-1

# Bucket S3 para armazenamento
# S3_BUCKET=leitura-ats-curriculos-dev

# -----------------------------------------------------------------------------
# Notas
# -----------------------------------------------------------------------------
# 
# Desenvolvimento:
#   - Use os valores padrão acima
#   - SECRET_KEY pode ser qualquer string
#   - FLASK_DEBUG=true para auto-reload
#
# Produção:
#   - Gere SECRET_KEY forte e única
#   - FLASK_ENV=production
#   - FLASK_DEBUG=false
#   - Configure AWS credentials via IAM Role (não aqui!)
